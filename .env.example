# Copy to .env and fill in. Read by src/lib/supabase.ts (fails loud if missing).
VITE_SUPABASE_URL=
# New Supabase PUBLISHABLE key (format: sb_publishable_…), from Dashboard >
# Settings > API Keys. Replaces the legacy anon key. Safe to ship in the browser.
# Do NOT put the secret key (sb_secret_…) here — it bypasses RLS and is server-only.
VITE_SB_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# SERVER-ONLY secrets — NEVER prefix these with VITE_ (that exposes them to the
# browser). They are consumed by the Supabase Edge Function that proxies Claude,
# NOT by the client. Set them with `supabase secrets set`, not in the client .env.
# ---------------------------------------------------------------------------
# Anthropic API key for the Claude proxy Edge Function (model: claude-opus-4-8).
# A Vite SPA cannot call the Anthropic API directly — the key would ship in the
# bundle. All Claude calls go through the server-side Edge Function. See PROJECT_STATE.md.
ANTHROPIC_API_KEY=
# Supabase SECRET key (sb_secret_…) for privileged server-side writes (e.g.
# promoting verification_status). Server-only; bypasses RLS.
SB_SECRET_KEY=

# Web Push (VAPID). Generate a keypair once with:  npx web-push generate-vapid-keys
# The PRIVATE key is server-only (Edge Function sender) — NEVER prefix it with VITE_.
VAPID_PRIVATE_KEY=
# mailto: or https: contact, required by the Web Push protocol.
VAPID_SUBJECT=mailto:hello@welcometothetable.app

# The VAPID PUBLIC key IS safe in the browser — it's the applicationServerKey passed
# to pushManager.subscribe(). It is the only VAPID value that may carry the VITE_ prefix.
VITE_VAPID_PUBLIC_KEY=
